---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const allPosts = await getCollection("blog");
const posts = (
	import.meta.env.PROD ? allPosts.filter((post) => !post.data.draft) : allPosts
)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="intro">
				<p class="eyebrow">&gt;_ systems &amp; software engineering</p>
				<h1>metalops<span class="dot">.</span>dev</h1>
				<p class="tagline">
				A technical blog about software, systems engineering, infrastructure and DevOps — from bare metal to production.
				</p>
			</section>

			<section class="posts">
				<div class="section-header">
					<h2>Recent Posts</h2>
					<a href="/blog" class="all-posts">view all &rarr;</a>
				</div>
				<ul>
					{
						posts.map((post, i) => (
							<li style={`animation-delay: ${i * 60}ms`}>
								<a href={`/blog/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 4rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}
	.eyebrow {
		font-family: "JetBrains Mono", "SF Mono", "Fira Code", monospace;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--accent);
		margin: 0 0 0.75rem 0;
	}
	.intro h1 {
		font-size: 3rem;
		margin: 0 0 1rem 0;
		line-height: 1.1;
		letter-spacing: -0.04em;
	}
	.dot {
		color: var(--accent);
	}
	.tagline {
		color: var(--muted);
		margin: 0;
		font-size: 1.1rem;
		line-height: 1.7;
		max-width: 520px;
	}
	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 1rem;
	}
	.posts h2 {
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 0;
		border: none;
		padding-left: 0;
	}
	.posts h2::before {
		display: none;
	}
	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	@keyframes slideIn {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.posts li {
		margin: 0;
		animation: slideIn 0.35s ease-out both;
	}
	.posts a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		padding: 0.875rem 0.75rem;
		text-decoration: none;
		color: var(--fg);
		border-bottom: none;
		border-radius: var(--radius, 6px);
		transition: background 0.15s, transform 0.15s;
		margin: 0 -0.75rem;
	}
	.posts a:hover {
		background: var(--surface);
		transform: translateX(4px);
		color: var(--fg);
	}
	.posts .title {
		font-weight: 500;
	}
	.posts .date {
		font-size: 0.8rem;
		color: var(--muted);
		flex-shrink: 0;
		font-family: "JetBrains Mono", "SF Mono", monospace;
		font-size: 0.75rem;
	}
	.all-posts {
		display: inline-block;
		font-size: 0.85rem;
		color: var(--accent);
		border-bottom: none;
		transition: gap 0.2s;
	}
	.all-posts:hover {
		color: var(--accent-light);
	}
	@media (max-width: 600px) {
		.intro h1 {
			font-size: 2.25rem;
		}
		.tagline {
			font-size: 1rem;
		}
	}
</style>
