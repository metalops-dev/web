---
import { siteConfig } from "../config/site";
---

<section class="comments">
	<h2>Comments</h2>
	<div class="giscus"></div>
</section>

<script
	src="https://giscus.app/client.js"
	data-repo={siteConfig.giscus.repo}
	data-repo-id={siteConfig.giscus.repoId}
	data-category={siteConfig.giscus.category}
	data-category-id={siteConfig.giscus.categoryId}
	data-mapping={siteConfig.giscus.mapping}
	data-strict={siteConfig.giscus.strict}
	data-reactions-enabled={siteConfig.giscus.reactionsEnabled}
	data-emit-metadata={siteConfig.giscus.emitMetadata}
	data-input-position={siteConfig.giscus.inputPosition}
	data-theme={siteConfig.giscus.theme}
	data-lang={siteConfig.giscus.lang}
	data-loading="lazy"
	crossorigin="anonymous"
	async
></script>

<style>
	.comments {
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}
	.comments h2 {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 1.5rem;
		color: var(--muted);
	}
</style>
